# Puerto del servidor HTTP
PORT=3001

# Opción A — una sola URL (recomendado en hosting)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_base

# Opción B — variables por separado (local o sin URL única)
PGHOST=localhost
PGPORT=5432
PGUSER=tu_usuario
PGPASSWORD=tu_contraseña
PGDATABASE=nombre_de_tu_base

# Esquema de tablas (en pgAdmin: web.exposiciones → PGSCHEMA=web)
PGSCHEMA=web
